<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GF Team - CT Funa Azevedo | Jiu-Jitsu & MMA em Nova Iguaçu</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@300;400;500;600;700&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  :root {
    --black: #0a0a0a;
    --dark: #111111;
    --dark2: #1a1a1a;
    --gold: #c9a84c;
    --gold2: #f0c040;
    --gold-light: #ffe17d;
    --white: #ffffff;
    --gray: #888888;
    --gray2: #333333;
    --green: #1a5c1a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Rajdhani', sans-serif;
    background: var(--black);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ========= SCROLLBAR ========= */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--dark); }
  ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

  /* ========= HEADER ========= */
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(10,10,10,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--gold);
    transition: all 0.3s;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .logo-area {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
  }

  .logo-badge {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: var(--black);
    font-weight: 900;
    letter-spacing: 1px;
    box-shadow: 0 0 20px rgba(201,168,76,0.4);
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .logo-badge img {
    width: 100%; height: 100%;
    object-fit: contain;
    border-radius: 50%;
  }

  .logo-text { line-height: 1.1; }
  .logo-text .main { font-family: 'Bebas Neue', sans-serif; font-size: 22px; color: var(--gold); letter-spacing: 2px; display: block; }
  .logo-text .sub { font-family: 'Oswald', sans-serif; font-size: 11px; color: var(--gray); letter-spacing: 3px; text-transform: uppercase; display: block; }

  nav { display: flex; align-items: center; gap: 6px; }

  nav a {
    color: var(--white);
    text-decoration: none;
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 14px;
    border-radius: 4px;
    transition: all 0.3s;
    position: relative;
  }

  nav a::after {
    content: '';
    position: absolute;
    bottom: 4px; left: 14px; right: 14px;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.3s;
  }

  nav a:hover { color: var(--gold); }
  nav a:hover::after { transform: scaleX(1); }

  .btn-header {
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    color: var(--black) !important;
    font-weight: 700;
    padding: 10px 22px !important;
    border-radius: 4px;
    letter-spacing: 2px;
    transition: all 0.3s !important;
    box-shadow: 0 4px 15px rgba(201,168,76,0.3);
  }

  .btn-header::after { display: none !important; }
  .btn-header:hover {
    background: linear-gradient(135deg, var(--gold2), var(--gold-light)) !important;
    box-shadow: 0 6px 25px rgba(201,168,76,0.5) !important;
    transform: translateY(-2px);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 5px;
  }

  .hamburger span {
    display: block; width: 28px; height: 2px;
    background: var(--gold);
    transition: all 0.3s;
    border-radius: 2px;
  }

  /* ========= HERO ========= */
  #inicio {
    height: 100vh;
    min-height: 700px;
    position: relative;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background-image: url('https://images.unsplash.com/photo-1555597673-b21d5c935865?w=1600&q=80');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    filter: brightness(0.3);
    transform: scale(1.05);
    transition: transform 8s ease;
  }

  .hero-bg.loaded { transform: scale(1); }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10,10,10,0.4) 0%,
      rgba(10,10,10,0.2) 40%,
      rgba(10,10,10,0.8) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    padding: 0 24px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(201,168,76,0.15);
    border: 1px solid rgba(201,168,76,0.4);
    color: var(--gold);
    padding: 8px 20px;
    border-radius: 30px;
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    font-family: 'Oswald', sans-serif;
    margin-bottom: 24px;
    animation: fadeInDown 1s ease 0.2s both;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(56px, 10vw, 110px);
    line-height: 0.95;
    letter-spacing: 4px;
    animation: fadeInUp 1s ease 0.4s both;
    text-shadow: 0 0 60px rgba(0,0,0,0.8);
  }

  .hero-title .gold { color: var(--gold); }

  .hero-sub {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(16px, 3vw, 22px);
    color: rgba(255,255,255,0.85);
    letter-spacing: 3px;
    margin: 20px 0 40px;
    text-transform: uppercase;
    animation: fadeInUp 1s ease 0.6s both;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeInUp 1s ease 0.8s both;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    color: var(--black);
    padding: 16px 36px;
    border: none;
    border-radius: 4px;
    font-family: 'Oswald', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s;
    box-shadow: 0 6px 25px rgba(201,168,76,0.35);
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 35px rgba(201,168,76,0.5);
    background: linear-gradient(135deg, var(--gold2), var(--gold-light));
  }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    padding: 16px 36px;
    border: 2px solid rgba(255,255,255,0.4);
    border-radius: 4px;
    font-family: 'Oswald', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--gold);
    color: var(--gold);
    transform: translateY(-3px);
  }

  .hero-scroll {
    position: absolute;
    bottom: 40px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.4);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    animation: bounce 2s infinite;
  }

  .hero-scroll i { font-size: 20px; }

  /* ========= STATS BAR ========= */
  .stats-bar {
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    padding: 0;
    overflow: hidden;
  }

  .stats-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .stat-item {
    padding: 28px 20px;
    text-align: center;
    border-right: 1px solid rgba(0,0,0,0.15);
    transition: background 0.3s;
    cursor: default;
  }

  .stat-item:last-child { border-right: none; }
  .stat-item:hover { background: rgba(0,0,0,0.1); }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    color: var(--black);
    line-height: 1;
    display: block;
  }

  .stat-label {
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    color: rgba(0,0,0,0.7);
    letter-spacing: 2px;
    text-transform: uppercase;
    display: block;
    margin-top: 4px;
  }

  /* ========= SECTIONS ========= */
  section { padding: 100px 24px; }

  .container { max-width: 1200px; margin: 0 auto; }

  .section-label {
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 40px; height: 2px;
    background: var(--gold);
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 6vw, 68px);
    letter-spacing: 2px;
    line-height: 1;
    color: var(--white);
  }

  .section-title .gold { color: var(--gold); }

  /* ========= SOBRE ========= */
  #sobre {
    background: var(--dark);
    position: relative;
    overflow: hidden;
  }

  #sobre::before {
    content: 'GF';
    position: absolute;
    right: -60px; top: 50%;
    transform: translateY(-50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 400px;
    color: rgba(201,168,76,0.04);
    line-height: 1;
    pointer-events: none;
  }

  .sobre-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .sobre-img {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
  }

  .sobre-img img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    display: block;
    filter: grayscale(20%);
    transition: filter 0.5s;
  }

  .sobre-img:hover img { filter: grayscale(0%); }

  .sobre-img::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px solid var(--gold);
    border-radius: 4px;
    transform: translate(10px, 10px);
    z-index: -1;
  }

  .sobre-img-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 30px;
    background: linear-gradient(to top, rgba(10,10,10,0.9), transparent);
  }

  .sobre-img-tag {
    display: inline-block;
    background: var(--gold);
    color: var(--black);
    padding: 6px 16px;
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    letter-spacing: 3px;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: 2px;
  }

  .sobre-text p {
    color: rgba(255,255,255,0.7);
    font-size: 17px;
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .sobre-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 30px;
  }

  .pillar {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 4px;
    padding: 14px 16px;
    transition: all 0.3s;
  }

  .pillar:hover {
    background: rgba(201,168,76,0.15);
    border-color: var(--gold);
    transform: translateX(4px);
  }

  .pillar i { color: var(--gold); font-size: 18px; flex-shrink: 0; }
  .pillar span {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--white);
  }

  /* ========= MODALIDADES ========= */
  #treinos { background: var(--black); }

  .treinos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 50px;
  }

  .treino-card {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 3/4;
    cursor: pointer;
    group: true;
  }

  .treino-card img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, filter 0.4s;
    filter: grayscale(30%) brightness(0.6);
  }

  .treino-card:hover img {
    transform: scale(1.08);
    filter: grayscale(0%) brightness(0.5);
  }

  .treino-card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.2) 60%, transparent 100%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 28px;
    transition: all 0.4s;
  }

  .treino-icon {
    width: 48px; height: 48px;
    background: var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px;
    transition: all 0.3s;
  }

  .treino-icon i { color: var(--black); font-size: 20px; }

  .treino-card:hover .treino-icon {
    background: var(--white);
    transform: scale(1.1);
  }

  .treino-card-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    color: var(--white);
  }

  .treino-card-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    margin-top: 6px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  .treino-card:hover .treino-card-desc { max-height: 80px; }

  .treino-card-tag {
    display: inline-block;
    background: rgba(201,168,76,0.25);
    color: var(--gold);
    padding: 4px 12px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 2px;
    margin-bottom: 8px;
    font-family: 'Oswald', sans-serif;
  }

  /* big card */
  .treino-card.big { grid-column: span 2; aspect-ratio: 16/9; }

  /* ========= DIFERENCIAIS ========= */
  #diferenciais {
    background: var(--dark);
    position: relative;
  }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    margin-top: 50px;
  }

  .diff-card {
    background: var(--dark2);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    padding: 36px 24px;
    text-align: center;
    transition: all 0.4s;
    position: relative;
    overflow: hidden;
  }

  .diff-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--gold2));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s;
  }

  .diff-card:hover {
    border-color: rgba(201,168,76,0.3);
    transform: translateY(-8px);
    background: rgba(201,168,76,0.05);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .diff-card:hover::before { transform: scaleX(1); }

  .diff-icon {
    font-size: 36px;
    color: var(--gold);
    margin-bottom: 20px;
    display: block;
    transition: transform 0.3s;
  }

  .diff-card:hover .diff-icon { transform: scale(1.2) rotate(5deg); }

  .diff-title {
    font-family: 'Oswald', sans-serif;
    font-size: 15px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    font-weight: 600;
  }

  .diff-desc {
    font-size: 13px;
    color: var(--gray);
    margin-top: 8px;
    line-height: 1.6;
  }

  /* ========= EQUIPE ========= */
  #equipe { background: var(--black); }

  .equipe-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    margin-top: 50px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .instructor-card {
    background: var(--dark2);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    transition: all 0.4s;
    position: relative;
  }

  .instructor-card:hover {
    border-color: var(--gold);
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.5), 0 0 30px rgba(201,168,76,0.15);
  }

  .instructor-img {
    height: 280px;
    background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .instructor-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition: all 0.4s;
  }

  .instructor-card:hover .instructor-img img {
    filter: grayscale(0%);
    transform: scale(1.05);
  }

  .instructor-avatar {
    width: 100px; height: 100px;
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 40px;
    color: var(--black);
  }

  .instructor-belt {
    position: absolute;
    top: 16px; right: 16px;
    background: var(--black);
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 4px 12px;
    font-size: 11px;
    font-family: 'Oswald', sans-serif;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 2px;
  }

  .instructor-info {
    padding: 24px;
  }

  .instructor-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    color: var(--white);
  }

  .instructor-role {
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    color: var(--gold);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .instructor-bio {
    font-size: 14px;
    color: var(--gray);
    margin-top: 12px;
    line-height: 1.6;
  }

  /* ========= GALERIA ========= */
  #galeria { background: var(--dark); padding: 80px 0; }

  .galeria-header {
    padding: 0 24px;
    margin-bottom: 40px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto;
    gap: 6px;
    padding: 0;
  }

  .galeria-item {
    overflow: hidden;
    position: relative;
    cursor: pointer;
  }

  .galeria-item:nth-child(1) { grid-column: span 2; grid-row: span 2; }

  .galeria-item img {
    width: 100%; height: 250px;
    object-fit: cover;
    transition: all 0.5s;
    filter: brightness(0.7) grayscale(20%);
    display: block;
  }

  .galeria-item:nth-child(1) img { height: 506px; }

  .galeria-item:hover img {
    transform: scale(1.08);
    filter: brightness(0.5) grayscale(0%);
  }

  .galeria-overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
    background: rgba(201,168,76,0.2);
  }

  .galeria-item:hover .galeria-overlay { opacity: 1; }
  .galeria-overlay i { color: var(--white); font-size: 28px; }

  /* ========= LOCALIZAÇÃO ========= */
  #localizacao { background: var(--black); }

  .loc-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 50px;
    align-items: start;
    margin-top: 50px;
  }

  .loc-info { }

  .loc-address {
    background: var(--dark2);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
    padding: 30px;
    margin-top: 24px;
  }

  .loc-address-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .loc-address-item:last-child { border-bottom: none; }

  .loc-address-item i {
    color: var(--gold);
    font-size: 18px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .loc-address-item div strong {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 4px;
  }

  .loc-address-item div span {
    color: rgba(255,255,255,0.7);
    font-size: 15px;
    line-height: 1.5;
  }

  .btn-maps {
    display: inline-flex;
