  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Arial', sans-serif;
    }

    body {
      background: #0a0a0a;
      color: #fff;
    }

    header {
      position: fixed;
      width: 100%;
      top: 0;
      background: rgba(0,0,0,0.9);
      backdrop-filter: blur(10px);
      display: flex;
      justify-content: space-between;
      padding: 20px 40px;
      z-index: 1000;
    }

    header h1 {
      color: #00ff88;
      font-weight: bold;
    }

    nav a {
      color: #fff;
      margin-left: 25px;
      text-decoration: none;
      transition: 0.3s;
    }

    nav a:hover {
      color: #00ff88;
    }

    .btn {
      background: #00ff88;
      color: #000;
      padding: 12px 25px;
      text-decoration: none;
      font-weight: bold;
      transition: 0.3s;
      border-radius: 5px;
    }

    .btn:hover {
      background: #00cc6a;
    }

    .hero {
      height: 100vh;
      background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.9)),
                  url('https://images.unsplash.com/photo-1554284126-aa88f22d8b74');
      background-size: cover;
      background-position: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 40px;
    }

    .hero h2 {
      font-size: 3.5rem;
      max-width: 600px;
    }

    .hero p {
      margin: 20px 0;
      color: #ccc;
      max-width: 500px;
    }

    section {
      padding: 100px 40px;
      max-width: 1200px;
      margin: auto;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-top: 40px;
    }

    .card {
      background: #111;
      padding: 25px;
      border-radius: 10px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
      background: #181818;
    }

    .plans {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 30px;
      margin-top: 40px;
    }

    .plan {
      background: #111;
      padding: 30px;
      border-radius: 15px;
      text-align: center;
      border: 1px solid #222;
    }

    .plan.highlight {
      border: 2px solid #00ff88;
      transform: scale(1.05);
    }

    .reviews {
      display: grid;
      gap: 20px;
      margin-top: 40px;
    }

    .review {
      background: #111;
      padding: 20px;
      border-left: 4px solid #00ff88;
    }

    footer {
      background: #000;
      text-align: center;
      padding: 30px;
    }

    iframe {
      width: 100%;
      height: 300px;
      margin-top: 20px;
      border: none;
    }

    @media(max-width: 768px){
      .hero h2 {
        font-size: 2.2rem;
      }
    }
  </style>
</head>

